# Copy this file to .env and fill in real values. Never commit .env.

# ODBC connection string for ReportManagementDB using the restricted app_role
# login (stored-procedure/function execution rights only, no direct table access).
APP_DB_CONN=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=ReportManagementDB;UID=app_role;PWD=changeme;

# Secret used to sign/verify JWT access tokens. Use a long random value.
JWT_SECRET=changeme-generate-a-long-random-secret

# Minutes before an issued JWT access token expires.
JWT_EXPIRE_MINUTES=60

# Symmetric key used to encrypt/decrypt stored credentials at rest.
CRED_ENCRYPTION_KEY=changeme-generate-a-fernet-key

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
